# Serveur
PORT=5000

# Base de données MongoDB
MONGO_URI=mongodb://localhost:27017/smart-auto

# Authentification
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Service IA Vision (Google Gemini — niveau gratuit) — RF2
# Clé gratuite : https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Optionnel : API tierce Google Lens (SerpApi ou SearchAPI.io)
# Améliore l'auto-détection en cherchant sur le web avec les pixels réels de l'image.
# Nécessite une clé API (gratuit avec quota limité, pas de carte bancaire).
#   SerpApi   : https://serpapi.com/google-lens-api  (100 recherches gratuites)
#   SearchAPI : https://www.searchapi.io/google-lens  (plan gratuit)
#
# Une seule clé :
LENS_API_KEY=ac6eca7c8559f7cc11ccd81938b6a16925be82662987633c778775fd9d24fae9,e6e10d0819aad05b349bd077ac0e16087820bb1c,
#
# Plusieurs clés (rotation automatique quand une clé atteint sa limite) :
# LENS_API_KEYS=key1,key2,key3,key4
#
LENS_API_PROVIDER=serpapi   # ou searchapi


# URL publique du backend (pour construire les liens d'images)
PUBLIC_URL=http://localhost:5000
